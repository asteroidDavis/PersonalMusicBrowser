# Backup service Dockerfile
FROM rust:1.75 as builder

WORKDIR /app
COPY Cargo_backup.toml Cargo.toml
COPY src/backup.rs src/backup.rs
COPY src/backup_main.rs src/main.rs

RUN cargo build --release

FROM debian:bookworm-slim

# Install SMB client and other utilities
RUN apt-get update && apt-get install -y \
    smbclient \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=builder /app/target/release/music-browser-backup /usr/local/bin/

CMD ["music-browser-backup", "--db-file", "/data/music_browser.db"]
